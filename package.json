{
  "name": "casos-reales",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "prisma migrate dev",
    "db:seed": "npx tsx prisma/seed.ts && npx tsx prisma/seed-part2.ts && npx tsx prisma/seed-part3.ts",
    "db:seed:part1": "npx tsx prisma/seed.ts",
    "db:seed:part2": "npx tsx prisma/seed-part2.ts",
    "db:seed:part3": "npx tsx prisma/seed-part3.ts",
    "db:reset": "prisma migrate reset --force",
    "db:images": "npx tsx prisma/update-victim-images.ts",
    "db:images:guide": "npx tsx prisma/update-victim-images.ts --guide"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "dompurify": "^3.3.1",
    "dotenv": "^17.2.3",
    "next": "16.1.1",
    "prisma": "^5.22.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
